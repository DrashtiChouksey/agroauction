# Server
NODE_ENV=development
PORT=5000
CLIENT_URL_PLATFORM=http://localhost:3001
CLIENT_URL_ADMIN=http://localhost:3002

# MongoDB
MONGO_URI=mongodb://mongo:27017/kisanbid
MONGO_URI_LOCAL=mongodb://localhost:27017/kisanbid

# Redis
REDIS_URL=redis://redis:6379
REDIS_URL_LOCAL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Admin
ADMIN_SECRET_CODE=ADMIN_2026
ADMIN_EMAIL=admin@kisanbid.com

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@kisanbid.com

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Platform
COMMISSION_PERCENT=5
DEFAULT_AUCTION_DURATION_HOURS=72
AUTO_EXTEND_MINUTES=5
